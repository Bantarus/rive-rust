# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# M0 example output
/out.png
/*.png

# premake-fetched dependencies cache (Vulkan-Headers, VMA, vk-bootstrap, ply).
# build.rs points $DEPENDENCIES here; it is large and reproducible, so not committed.
/.rive-deps/

# rive-runtime build artifacts (generated into the submodule's out/ tree by premake+make)
/vendor/rive-runtime/out/
/vendor/rive-runtime/**/out/
/vendor/rive-runtime/dependencies/*_*/

# Vendored premake5 binaries: Linux ELF via tools/fetch_premake.sh (beta2),
# Windows .exe via tools/fetch_premake.cmd (beta7). Not tracked; build.rs falls
# back to $PREMAKE5 / PATH. The fetch scripts themselves ARE tracked.
/tools/premake5
/tools/*.exe
/tools/*.so
/tools/*.so.debug

# Editor / OS
.DS_Store
*.swp
